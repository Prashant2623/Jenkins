pipeline {
    agent any 
    tools{             
        maven 'maven-3.8'  
        }
    stages{
        stage('build jar') {
            steps {
                script {
                    echo "Building the application..."
                    sh 'mvn package'
                }
            }
        }
        stage('build image') {
            steps {
                script {
                    echo "Building the dockerimage..."
                    withCredentials([usernamePassword(credentialsId: 'docker-hub', passwordVariable: 'PASS', usernameVariable: 'USER')]){
                        sh 'docker build -t docker2624/demoapp .'
                        sh "echo $docker2624 | docker login -u $docker2624 --password-stdin"
                        sh 'docker push docker2624/demoapp'
                    }
                }
            }
        }
        stage('deploy') {
            steps {
                script {
                    echo "deploying the application..."    
                }
            }        }
    }
}